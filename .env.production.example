APP_BASE_URL=https://teamswork.example.com
APP_ENV=production
DATABASE_URL=postgresql://teamswork:teamswork@postgres:5432/teamswork
AUTH_JWT_SECRET=change-this-production-secret
AUTH_JWT_ALGORITHM=HS256
AUTH_DISABLE_JWT_VALIDATION=false
AUTH_ALLOW_HEADER_FALLBACK=false
TEAMS_CLIENT_ID=
TEAMS_TENANT_ID=
TEAMS_CLIENT_SECRET=
TEAMS_INCOMING_WEBHOOK_URL=
TEAMS_CHANNEL_ID=
TEAMS_SERVICE_URL=
TEAMS_DISABLE_JWT_VALIDATION=false
TEAMS_PROACTIVE_MODE=bot
TEAMS_BOT_APP_ID=
TEAMS_BOT_APP_SECRET=
RAG_VECTOR_BACKEND=pgvector
RAG_EMBEDDING_ENABLED=false
RAG_EMBEDDING_PROVIDER=openai_compatible
RAG_EMBEDDING_MODEL=text-embedding-3-small
RAG_EMBEDDING_DIM=1536
RAG_SCORE_THRESHOLD=0.45
RAG_SEARCH_LIMIT=5
RAG_STORAGE_ROOT=.data/rag_uploads
RAG_PDF_ENABLED=false
