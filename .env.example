APP_BASE_URL=http://localhost:8000
APP_ENV=development
DATABASE_URL=postgresql://teamswork:teamswork@localhost:5432/teamswork
DATABASE_URL_DOCKER=postgresql://teamswork:teamswork@postgres:5432/teamswork
AUTH_JWT_SECRET=dev-secret-change-me
AUTH_JWT_ALGORITHM=HS256
AUTH_DISABLE_JWT_VALIDATION=true
AUTH_ALLOW_HEADER_FALLBACK=true
AUTH_ALLOWED_EMAIL_DOMAINS=
AUTH_FAILED_LOGIN_LIMIT=5
AUTH_FAILED_LOGIN_WINDOW_MINUTES=30
AUTH_FAILED_LOGIN_BLOCK_MINUTES=30
SECURITY_HSTS_ENABLED=false
TEAMS_CLIENT_ID=
TEAMS_TENANT_ID=common
TEAMS_CLIENT_SECRET=
TEAMS_INCOMING_WEBHOOK_URL=
TEAMS_CHANNEL_ID=
TEAMS_SERVICE_URL=
TEAMS_DISABLE_JWT_VALIDATION=true
TEAMS_PROACTIVE_MODE=webhook
TEAMS_BOT_APP_ID=
TEAMS_BOT_APP_SECRET=
TEAMS_GRAPH_TEAM_ID=
TEAMS_GRAPH_CHANNEL_ID=
AI_PROVIDER=openai_compatible
AI_API_KEY=ollama
AI_BASE_URL=http://localhost:11434/v1
AI_MODEL=qwen3:8b
AI_FALLBACK_MODEL=qwen2.5:7b
AI_TASK_BREAKDOWN_TIMEOUT_SECONDS=20
RAG_VECTOR_BACKEND=pgvector
RAG_EMBEDDING_ENABLED=false
RAG_EMBEDDING_PROVIDER=openai_compatible
RAG_EMBEDDING_MODEL=text-embedding-3-small
RAG_EMBEDDING_DIM=1536
RAG_SCORE_THRESHOLD=0.45
RAG_SEARCH_LIMIT=5
RAG_STORAGE_ROOT=.data/rag_uploads
RAG_PDF_ENABLED=false
